# Gemini API 配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI Compatible API 配置
OPENAI_COMPATIBLE_API_KEY=your_openai_compatible_api_key
OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1
OPENAI_COMPATIBLE_MODEL=your_model_name

# Tavily Search（可选：用于替代直接爬 Google 获取新闻）
TAVILY_API_KEY=your_tavily_api_key_here

# 新闻获取控制（可选）
# - NEWS_MAX_NEWS: get_stock_news 的全局上限（默认 100，最大 100）
# - TAVILY_MAX_NEWS: Tavily 单次最多拉取条数（默认 20，最大 20）
NEWS_MAX_NEWS=100
TAVILY_MAX_NEWS=20

# LLM 结果缓存文件路径（可选）

# AkShare 代理轮询（默认 direct 表示不走代理，如果没有代理池，下面的参数不需要修改）
# 如需使用共享代理池，设置为逗号/分号分隔的列表，如：
# AKSHARE_PROXY_LIST=hdirect
AKSHARE_PROXY_LIST=direct
AKSHARE_PROXY_MAX_ATTEMPTS=3
AKSHARE_PROXY_BASE_DELAY=1
AKSHARE_PROXY_MAX_DELAY=15
AKSHARE_PROXY_JITTER=0.5
AKSHARE_PROXY_ALLOW_DIRECT=true

# SQLite 缓存数据库路径（可选，不填则默认 data/market_data_cache.db）
# MARKET_CACHE_DB_PATH=data/market_data_cache.db
